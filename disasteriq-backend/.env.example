# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://disasteriq:disasteriq_pass@localhost:5432/disasteriq_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── OpenWeatherMap ──────────────────────────────────────────────────────────
# Free tier: https://openweathermap.org/api
# Leave blank to use built-in mock weather data
OPENWEATHER_API_KEY=

# ─── AI Report Generation ────────────────────────────────────────────────────
# Claude API: https://console.anthropic.com/
# Leave blank to use template-based mock reports
CLAUDE_API_KEY=

# ─── Twilio SMS / WhatsApp ───────────────────────────────────────────────────
# Leave blank to use simulation mode (logs to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "demo" to use mock data for all external services
APP_ENV=demo
DEBUG=true
